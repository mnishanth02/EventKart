{
	"name": "eventkart",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint lint:root",
		"lint:root": "biome lint package.json turbo.json biome.json",
		"format": "turbo run format format:root format:docs",
		"format:root": "biome format --write package.json turbo.json biome.json",
		"format:docs": "prettier --write \"**/*.md\"",
		"check": "turbo run check check:root",
		"check:root": "biome check package.json turbo.json biome.json",
		"test": "turbo run test",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:report": "playwright show-report",
		"check-types": "turbo run check-types",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:reset": "docker compose down -v"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@playwright/test": "^1.59.1",
		"prettier": "^3.8.3",
		"turbo": "^2.9.6",
		"typescript": "^6.0.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss"
		]
	},
	"packageManager": "pnpm@10.33.2",
	"engines": {
		"node": ">=22.12.0"
	}
}
