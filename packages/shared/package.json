		"test": "vitest run"
	},
	"dependencies": {
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@repo/typescript-config": "workspace:*",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
