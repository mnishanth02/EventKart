{
	"name": "@repo/shared",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		"./schemas": "./src/schemas/index.ts",
		"./schemas/*": "./src/schemas/*.ts",
		"./constants": "./src/constants/index.ts",
		"./constants/*": "./src/constants/*.ts",
		"./types": "./src/types/index.ts",
		"./types/*": "./src/types/*.ts",
		"./utils": "./src/utils/index.ts",
		"./utils/*": "./src/utils/*.ts"
	},
