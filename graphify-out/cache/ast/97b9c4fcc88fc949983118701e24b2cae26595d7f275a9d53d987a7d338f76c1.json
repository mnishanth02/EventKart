otes are internal and optional.\"}{\" \"}\n\t\t\t\t\t\t\t{trimmedLength}/2000\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t{isReject && trimmedLength > 0 && trimmedLength < 10 ? (\n\t\t\t\t\t\t\t<p id={errorId} className=\"text-sm text-destructive\" role=\"alert\">\n\t\t\t\t\t\t\t\tReason must be at least 10 characters ({trimmedLength}/10)\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t) : null}\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<DialogFooter>\n\t\t\t\t\t\t<Button\n\t\t\t\t\t\t\ttype=\"button\"\n\t\t\t\t\t\t\tvariant=\"outline\"\n\t\t\t\t\t\t\tonClick={()", "is_member_call": false, "source_file": "C:\\Users\\v-mnmurugan\\projects\\eventKart\\apps\\web\\src\\features\\admin\\components\\review-action-dialog.tsx", "source_location": "L91"}]}