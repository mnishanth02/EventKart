{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api/Dockerfile",
    "watchPatterns": [
      "apps/api/**",
      "packages/db/**",
      "packages/shared/**",
      "packages/typescript-config/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "turbo.json",
      "tsconfig.json"
    ]
  },
  "deploy": {
    "startCommand": "node --import tsx dist/workers/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "drainingSeconds": 60,
    "overlapSeconds": 0
  }
}
