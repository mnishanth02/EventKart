{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"transit": {
			"dependsOn": ["^transit"]
		},
		"build": {
			"dependsOn": ["^build"]
		},
		"lint": {
			"inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/biome.json"]
		},
		"check-types": {
			"dependsOn": ["transit"]
		},
		"check": {
			"inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/biome.json"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"format": {
			"cache": false
		},
		"test": {},
		"//#lint:root": {
			"inputs": ["package.json", "turbo.json", "biome.json"]
		},
		"//#format:root": {
			"cache": false,
			"inputs": ["package.json", "turbo.json", "biome.json"]
		},
		"//#check:root": {
			"inputs": ["package.json", "turbo.json", "biome.json"]
		},
		"//#format:docs": {
			"cache": false,
			"inputs": ["**/*.md"]
		}
	}
}
