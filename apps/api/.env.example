# Copy this file to `.env` for local development.

# Runtime server binding
HOST=0.0.0.0
PORT=3001

# Fastify logger level
LOG_LEVEL=info

# Browser origin allowed to call the API in local development
WEB_ORIGIN=http://localhost:3000

# Internal SSR/app communication key (optional for local development)
# INTERNAL_API_KEY=replace-me

# PostgreSQL connection string (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://eventkart:eventkart_dev@localhost:5432/eventkart_dev

# Redis connection string (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Object storage (S3/R2) — optional for local development
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=replace-me
# S3_SECRET_ACCESS_KEY=replace-me
# S3_BUCKET=eventkart-dev
# S3_FORCE_PATH_STYLE=true

# OTP delivery configuration
# Mode: "log" (default, logs OTP to console) or "msg91" (sends via MSG91 API)
OTP_DELIVERY_MODE=log
# MSG91_AUTH_KEY=replace-me
# MSG91_OTP_TEMPLATE_ID=replace-me

# Session / Cookie
# COOKIE_DOMAIN=.eventkart.app   # Set in production for cross-subdomain cookies

# CSRF protection secret — use a strong random value in production
# CSRF_SECRET=replace-me-with-random-secret

# Admin IP allowlist — comma-separated IPs and/or CIDR ranges
# When unset, admin IP restriction is disabled (suitable for local development)
# ADMIN_IP_ALLOWLIST=10.0.0.1,192.168.1.0/24,::1

# Email delivery (Resend)
# When RESEND_API_KEY is not set, emails are logged to console (like OTP_DELIVERY_MODE=log)
# RESEND_API_KEY=re_replace-me
EMAIL_FROM=EventKart <noreply@eventkart.app>

# Logging
# LOG_PRETTY=true  # Set to true for human-readable logs in development

# OpenTelemetry (optional — enables distributed tracing)
# OTEL_SERVICE_NAME=eventkart-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=

# Sentry error tracking (optional — enables error tracking + performance monitoring)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Razorpay payment gateway (optional for local development)
# When not set, Razorpay integration is disabled (account creation is a no-op)
# RAZORPAY_KEY_ID=rzp_test_replace-me
# RAZORPAY_KEY_SECRET=replace-me

# Public "spots remaining" capacity badge feature flag.
# When false (default), the public event-detail API projects `capacity: null`
# for every category, hiding stored spotsTotal/spotsRemaining from clients.
# Must match `VITE_PUBLIC_SPOTS_REMAINING_BADGE_ENABLED` in apps/web; both
# must be true for the badge to render. Keep false until I-3.2.10 atomic
# capacity decrement ships.
# PUBLIC_SPOTS_REMAINING_BADGE_ENABLED=false

# Cloudflare CDN integration (I-2.4.1 setup, I-2.4.2 purge client).
# All four are OPTIONAL — when CLOUDFLARE_PURGE_ENABLED is unset or false
# the API does not contact Cloudflare and dev/test runs do not need a real
# zone. See `docs/operations/cloudflare-cdn-setup.md` for the zone
# configuration runbook (DNS, SSL, page rules, cache contract, token
# rotation).
#
# CLOUDFLARE_ZONE_ID — Cloudflare zone identifier for eventkart.in (or the
# active production apex). Found in the Cloudflare dashboard → Overview.
# CLOUDFLARE_ZONE_ID=replace-me
#
# CLOUDFLARE_API_TOKEN — scoped API token with `Zone.Cache Purge` only.
# NEVER use the global API key. Rotate per the runbook (90-day cadence).
# Stored as a Railway secret in production; do NOT commit a real value.
# CLOUDFLARE_API_TOKEN=replace-me
#
# CLOUDFLARE_PURGE_ENABLED — string boolean ("true" / "false"). When false
# (default) the I-2.4.2 purge client is a log-only no-op so local + CI
# never hit the Cloudflare API. When true, both CLOUDFLARE_ZONE_ID and
# CLOUDFLARE_API_TOKEN MUST also be set or `loadConfig` will throw at
# boot (fail-closed; prevents silent stale-cache outages in production).
# CLOUDFLARE_PURGE_ENABLED=false
#
# CDN_BASE_URL — public site origin used by the I-2.4.2 purge client to
# build absolute cache keys (e.g., `https://eventkart.in/events/<slug>`).
# MUST be an absolute origin with no path / query / hash, and is normally
# the apex production domain. When unset, the purge client falls back to
# tag-based purge only.
# CDN_BASE_URL=https://eventkart.in
