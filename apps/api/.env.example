# Copy this file to `.env` for local development.

# Runtime server binding
HOST=0.0.0.0
PORT=3001

# Fastify logger level
LOG_LEVEL=info

# Browser origin allowed to call the API in local development
WEB_ORIGIN=http://localhost:3000

# Internal SSR/app communication key (optional for local development)
# INTERNAL_API_KEY=replace-me

# PostgreSQL connection string (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://eventkart:eventkart_dev@localhost:5432/eventkart_dev

# Redis connection string (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Object storage (S3/R2) — optional for local development
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=replace-me
# S3_SECRET_ACCESS_KEY=replace-me
# S3_BUCKET=eventkart-dev
# S3_FORCE_PATH_STYLE=true

# OTP delivery configuration
# Mode: "log" (default, logs OTP to console) or "msg91" (sends via MSG91 API)
OTP_DELIVERY_MODE=log
# MSG91_AUTH_KEY=replace-me
# MSG91_OTP_TEMPLATE_ID=replace-me

# Session / Cookie
# COOKIE_DOMAIN=.eventkart.app   # Set in production for cross-subdomain cookies

# CSRF protection secret — use a strong random value in production
# CSRF_SECRET=replace-me-with-random-secret

# Admin IP allowlist — comma-separated IPs and/or CIDR ranges
# When unset, admin IP restriction is disabled (suitable for local development)
# ADMIN_IP_ALLOWLIST=10.0.0.1,192.168.1.0/24,::1

# Email delivery (Resend)
# When RESEND_API_KEY is not set, emails are logged to console (like OTP_DELIVERY_MODE=log)
# RESEND_API_KEY=re_replace-me
EMAIL_FROM=EventKart <noreply@eventkart.app>
