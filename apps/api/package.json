{
	"name": "api",
	"version": "1.0.0",
	"description": "TypeScript-first Fastify API baseline for eventKart.",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsx watch src/server.ts",
		"start": "tsx src/server.ts",
		"start:prod": "node dist/server.js",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check-types": "tsc --noEmit",
		"test": "vitest run"
	},
	"license": "MIT",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1034.0",
		"@aws-sdk/s3-request-presigner": "^3.1034.0",
		"@fastify/cors": "^11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/type-provider-zod": "^1.0.0",
		"@repo/shared": "workspace:*",
		"@sinclair/typebox": "^0.34.41",
		"bullmq": "^5.75.2",
		"env-schema": "^7.0.0",
		"fastify": "^5.8.5",
		"fastify-plugin": "^5.1.0",
		"ioredis": "^5.10.1",
		"tsx": "^4.20.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	}
}
