{
	"name": "api",
	"version": "1.0.0",
	"description": "TypeScript-first Fastify API baseline for eventKart.",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsx watch src/server.ts",
		"start": "tsx src/server.ts",
		"start:worker": "tsx src/workers/index.ts",
		"start:prod": "node dist/server.js",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check-types": "tsc --noEmit",
		"test": "vitest run"
	},
	"license": "MIT",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1034.0",
		"@aws-sdk/s3-request-presigner": "^3.1034.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/rate-limit": "^10.3.0",
		"@fastify/type-provider-zod": "^1.0.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
		"@opentelemetry/instrumentation-fastify": "^0.57.0",
		"@opentelemetry/instrumentation-http": "^0.215.0",
		"@opentelemetry/instrumentation-pino": "^0.61.0",
		"@opentelemetry/resources": "^2.7.0",
		"@opentelemetry/sdk-metrics": "^2.7.0",
		"@opentelemetry/sdk-node": "^0.215.0",
		"@repo/db": "workspace:*",
		"@repo/shared": "workspace:*",
		"@sentry/node": "^10.49.0",
		"@sinclair/typebox": "^0.34.49",
		"bullmq": "^5.76.0",
		"drizzle-orm": "^0.45.2",
		"env-schema": "^7.0.0",
		"fastify": "^5.8.5",
		"fastify-plugin": "^5.1.0",
		"ioredis": "^5.10.1",
		"razorpay": "^2.9.6",
		"tsx": "^4.21.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/node": "^25.6.0",
		"pino-pretty": "^13.1.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
