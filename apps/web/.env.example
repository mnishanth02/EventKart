# Copy this file to `.env.local` for local development.

# Public client-safe configuration
VITE_APP_TITLE=eventKart
VITE_API_URL=http://localhost:3001
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Server-only configuration
INTERNAL_API_URL=http://localhost:3001
SERVER_URL=http://localhost:3000
# Internal API key for server-to-server calls (must match apps/api INTERNAL_API_KEY)
# INTERNAL_API_KEY=replace-me

# Sentry error tracking (optional — enables error tracking + performance monitoring)
# Public (client-safe, embedded in browser bundle)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# Server runtime
# SENTRY_DSN=https://examplePrivateKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Server-only (for source map upload during CI/CD builds)
# SENTRY_AUTH_TOKEN=sntrys_replace-me
# SENTRY_ORG=your-org
# SENTRY_PROJECT=eventkart-web
