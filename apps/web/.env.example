# Copy this file to `.env.local` for local development.

# Public client-safe configuration
VITE_APP_TITLE=eventKart
# Public, browser-facing API origin. Local dev: http://localhost:3001.
# On Railway: use the public custom domain, e.g.
#   https://api-staging.eventkart.run (staging) / https://api.eventkart.run (production).
VITE_API_URL=http://localhost:3001
# Public canonical origin for share previews (Open Graph og:url + <link rel="canonical">).
# Optional: when unset, those tags are omitted and the page still renders.
# In production this should match SERVER_URL (server-only) but they are kept
# separate because publicEnv is bundled to the browser.
VITE_SITE_URL=http://localhost:3000
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Public support phone shown on /contact when phone support is enabled.
# Leave blank to hide the phone affordance in local/dev environments.
VITE_PUBLIC_SUPPORT_PHONE=

# I-2.1.9: enable per-category spots-remaining badge on /events/:slug.
# Keep false until I-3.2.10 (atomic capacity decrement + CDN purge on capacity changes) ships.
VITE_PUBLIC_SPOTS_REMAINING_BADGE_ENABLED=false

# Server-only configuration
# INTERNAL_API_URL — Server-side SSR -> API hop. Local dev: http://localhost:3001.
# On Railway: use the private network domain, e.g.
#   INTERNAL_API_URL=http://${{api.RAILWAY_PRIVATE_DOMAIN}}:3001
# (equivalent to http://api.railway.internal:3001). Avoids public egress + TLS.
INTERNAL_API_URL=http://localhost:3001
SERVER_URL=http://localhost:3000
# Internal API key for server-to-server calls (must match apps/api INTERNAL_API_KEY)
# INTERNAL_API_KEY=replace-me

# Sentry error tracking (optional — enables error tracking + performance monitoring)
# Public (client-safe, embedded in browser bundle)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# Server runtime
# SENTRY_DSN=https://examplePrivateKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Server-only (for source map upload during CI/CD builds)
# SENTRY_AUTH_TOKEN=sntrys_replace-me
# SENTRY_ORG=your-org
# SENTRY_PROJECT=eventkart-web
